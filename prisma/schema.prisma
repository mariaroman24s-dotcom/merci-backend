generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model agentes_virtuales {
  id                        String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  empresa_id                String                  @db.Uuid
  departamento_id           String?                 @db.Uuid
  sucursal_id               String?                 @db.Uuid
  numero_entrada            String?                 @db.VarChar(10)
  nombre                    String                  @db.VarChar(100)
  descripcion               String?
  tipo_agente_id            String?                 @db.Uuid
  estado_agente_id          String?                 @db.Uuid
  calendario_id             String?                 @db.Uuid
  pbx_ivr_id                String?                 @db.VarChar(50)
  pbx_extension             String?                 @db.VarChar(10)
  grupo_atencion_default_id String?                 @db.Uuid
  deleted_at                DateTime?               @db.Timestamp(6)
  fecha_registro            DateTime?               @default(now()) @db.Timestamp(6)
  fecha_actualizacion       DateTime?               @default(now()) @db.Timestamp(6)
  calendarios               calendarios?            @relation(fields: [calendario_id], references: [id], onUpdate: NoAction, map: "fk_av_calendario")
  departamentos             departamentos?          @relation(fields: [departamento_id], references: [id], onUpdate: NoAction, map: "fk_av_departamento")
  empresas                  empresas                @relation(fields: [empresa_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_av_empresa")
  catalogo_estado_agente    catalogo_estado_agente? @relation(fields: [estado_agente_id], references: [id], onUpdate: NoAction, map: "fk_av_estado")
  grupos_atencion           grupos_atencion?        @relation(fields: [grupo_atencion_default_id], references: [id], onUpdate: NoAction, map: "fk_av_grupo_default")
  sucursales                sucursales?             @relation(fields: [sucursal_id], references: [id], onUpdate: NoAction, map: "fk_av_sucursal")
  catalogo_tipo_agente      catalogo_tipo_agente?   @relation(fields: [tipo_agente_id], references: [id], onUpdate: NoAction, map: "fk_av_tipo")
  llamadas                  llamadas[]
  versiones_prompt          versiones_prompt[]

  @@index([empresa_id], map: "idx_agentes_empresa")
}

model auditoria_logs {
  id               BigInt    @id @default(autoincrement())
  empresa_id       String    @db.Uuid
  usuario_id       String?   @db.Uuid
  ip               String?   @db.VarChar(45)
  modulo           String?   @db.VarChar(100)
  accion           String    @db.VarChar(100)
  tabla_afectada   String?   @db.VarChar(100)
  registro_id      String?   @db.Uuid
  datos_anteriores Json?
  datos_nuevos     Json?
  fecha_evento     DateTime? @default(now()) @db.Timestamp(6)
  empresas         empresas  @relation(fields: [empresa_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_audit_empresa")
  usuarios         usuarios? @relation(fields: [usuario_id], references: [id], onUpdate: NoAction, map: "fk_audit_usuario")

  @@index([empresa_id], map: "idx_auditoria_empresa")
  @@index([fecha_evento], map: "idx_auditoria_fecha")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model auditorias_comandos_ia {
  id                 BigInt    @id @default(autoincrement())
  empresa_id         String    @db.Uuid
  usuario_id         String    @db.Uuid
  llamada_id         String?   @db.Uuid
  comando_voz_puro   String
  json_deducido      Json?
  tokens_consumidos  Int?
  status_resultado   String    @db.VarChar(20)
  respuesta_hardware Json?
  fecha_ejecucion    DateTime? @default(now()) @db.Timestamp(6)
  empresas           empresas  @relation(fields: [empresa_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_acia_empresa")
  llamadas           llamadas? @relation(fields: [llamada_id], references: [id], onUpdate: NoAction, map: "fk_acia_llamada")
  usuarios           usuarios  @relation(fields: [usuario_id], references: [id], onUpdate: NoAction, map: "fk_acia_usuario")

  @@index([empresa_id, fecha_ejecucion], map: "idx_auditoria_ia_empresa_fecha")
}

